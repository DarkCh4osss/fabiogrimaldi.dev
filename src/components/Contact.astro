<section class="contact__section">
  <div class="row title__row">
    <div class="col-2 title__sect">
      <h1>Stay in touch</h1>
    </div>
    <div class="col-2"></div>
  </div>
  <div class="row contact__row">
    <div class="col-2 contact__desc">
      <p>
        Feel free to contact me for any types of projects. If you find some
        bugs, please report them here.
      </p>
    </div>
    <!-- <div class="line contact__line"></div> -->
    <div class="col-2 contact__form">
      <form name="contact" method="POST" netlify>
        <input type="text" name="name" placeholder="Name" required />
        <input type="text" name="email" placeholder="Email" required />
        <textarea name="message" placeholder="Message" required></textarea>
        <button type="submit">SEND</button>
      </form>
    </div>
  </div>
</section>
